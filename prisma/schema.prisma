generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  avatar    String?
  role      String   @default("user")
  tier      String   @default("free")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  calculations CalculationHistory[]
  savedData    UserSavedData[]
}

// ─── Equation Categories ───
model EquationCategory {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  icon        String?
  description String?
  domain      String
  color       String?
  parentId    String?
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  equations  Equation[]
  parent     EquationCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children   EquationCategory[] @relation("CategoryHierarchy")
}

// ─── Equations ───
model Equation {
  id               String   @id @default(cuid())
  equationId       String   @unique   // e.g. "eq_ohms_law"
  name             String
  formula          String   // human-readable formula string
  description      String?
  domain           String
  difficulty       String   @default("intermediate")
  equationLatex    String?  // LaTeX formatted formula
  equationPattern  String?  // Pattern for bidirectional solving
  tags             String?  // JSON array string
  isActive         Boolean  @default(true)
  category         String?  // Category name (denormalized for quick access)
  reference        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  categoryId String?
  categoryRef EquationCategory? @relation(fields: [categoryId], references: [id])
  inputs     EquationInput[]
  outputs    EquationOutput[]
}

model EquationInput {
  id              String  @id @default(cuid())
  name            String
  symbol          String?
  description     String?
  unit            String?
  unitCategory    String?
  dataType        String  @default("number")
  required        Boolean @default(true)
  defaultVal      String?
  min             String?
  max             String?
  validationRegex String?
  order           Int     @default(0)
  placeholder     String?
  helpText        String?
  step            String?

  equationId String
  equation   Equation @relation(fields: [equationId], references: [id], onDelete: Cascade)
}

model EquationOutput {
  id            String  @id @default(cuid())
  name          String
  symbol        String?
  description   String?
  unit          String?
  unitCategory  String?
  dataType      String  @default("number")
  formula       String?
  order         Int     @default(0)
  precision     Int     @default(4)
  formatString  String?

  equationId String
  equation   Equation @relation(fields: [equationId], references: [id], onDelete: Cascade)
}

// ─── Calculation Pipelines ───
model CalculationPipeline {
  id              String   @id @default(cuid())
  pipelineId      String   @unique  // e.g. "cable_sizing_iec"
  name            String
  slug            String   @unique
  description     String?
  domain          String
  category        String?
  difficulty      String   @default("intermediate")
  icon            String?
  tags            String?  // JSON array
  standardId      String?
  version         String?
  estimatedTime   String?
  isActive        Boolean  @default(true)
  isLocal         Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  steps        PipelineStep[]
  dependencies PipelineDependency[] @relation("PipelineDeps")
}

model PipelineStep {
  id               String  @id @default(cuid())
  stepId           String? // e.g. "step_1"
  name             String
  description      String?
  order            Int
  formula          String?
  formulaRef       String? // Reference to equation
  inputConfig      String? // JSON
  outputConfig     String? // JSON
  inputSchema      String? // JSON (legacy)
  outputSchema     String? // JSON (legacy)
  helperText       String?
  calculationType  String?
  stepType         String?
  precision        Int?
  validationConfig String? // JSON

  pipelineId String
  pipeline   CalculationPipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  stepDependencies   PipelineDependency[] @relation("StepDependency")
  dependsOnRelations PipelineDependency[] @relation("DependsOnStep")
}

model PipelineDependency {
  id           String  @id @default(cuid())
  inputMapping String? // JSON

  pipelineId     String
  stepId         String
  dependsOnId    String

  pipeline      CalculationPipeline @relation("PipelineDeps", fields: [pipelineId], references: [id], onDelete: Cascade)
  step          PipelineStep        @relation("StepDependency", fields: [stepId], references: [id], onDelete: Cascade)
  dependsOnStep PipelineStep        @relation("DependsOnStep", fields: [dependsOnId], references: [id], onDelete: Cascade)
}

// ─── Engineering Standards ───
model EngineeringStandard {
  id           String   @id @default(cuid())
  standardCode String   @unique
  name         String
  description  String?
  standardType String
  domain       String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  coefficients StandardCoefficient[]
}

model StandardCoefficient {
  id               String  @id @default(cuid())
  coefficientName  String
  coefficientType  String
  dataSource       String
  coefficientTable String? // JSON
  formula          String?
  externalReference String?

  standardId String
  standard   EngineeringStandard @relation(fields: [standardId], references: [id], onDelete: Cascade)
}

// ─── Report Templates ───
model ReportTemplate {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  description  String?
  category     String?
  templateType String   @default("technical")
  sections     String?  // JSON
  styling      String?  // JSON
  isPublic     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── Calculation History ───
model CalculationHistory {
  id         String   @id @default(cuid())
  equationId String?
  pipelineId String?
  inputs     String
  outputs    String
  type       String   @default("equation")
  createdAt  DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Courses (from engmastery.db) ───
model Course {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  domain      String
  discipline  String?
  level       String   @default("beginner")
  duration    String?
  icon        String?
  image       String?
  rating      String   @default("0")
  enrolled    Int      @default(0)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  modules CourseModule[]
}

model CourseModule {
  id          String  @id @default(cuid())
  title       String
  description String?
  order       Int
  duration    String?

  courseId String
  course   Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]
  chapters Chapter[]
}

model Chapter {
  id          String  @id @default(cuid())
  title       String
  order       Int

  moduleId String
  module   CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  lessons Lesson[]
}

model Lesson {
  id          String  @id @default(cuid())
  title       String
  description String?
  type        String  @default("article")
  content     String?
  duration    String?
  order       Int
  isFree      Boolean @default(true)

  moduleId  String?
  module    CourseModule?  @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  chapterId String?
  chapter   Chapter?       @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  quizzes   Quiz[]
}

model Quiz {
  id        String  @id @default(cuid())
  questions String  // JSON array of questions

  lessonId String
  lesson   Lesson  @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

// ─── User Saved Data ───
model UserSavedData {
  id        String   @id @default(cuid())
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
}

// ─── Unit Conversions ───
model UnitConversion {
  id         String  @id @default(cuid())
  category   String
  fromUnit   String
  toUnit     String
  factor     String
  offset     String  @default("0")
  fromSymbol String?
  toSymbol   String?
}

// ─── Engineering Reference Data (from Excel sheets) ───
model EngineeringReferenceData {
  id          String  @id @default(cuid())
  category    String  // e.g. "cable_impedance", "xlpe_library", "motor_ratings", "busbar_derating"
  subCategory String? // e.g. "PVC", "XLPE", "K1", "K2"
  key         String  // unique key within category (e.g. "16", "copper", "A")
  label       String? // human-readable label
  value       String  // JSON string with all data fields
  unit        String? // unit of measurement
  standard    String? // reference standard (e.g. "IEC 60364-5-52")
  order       Int     @default(0)

  @@unique([category, subCategory, key])
}
